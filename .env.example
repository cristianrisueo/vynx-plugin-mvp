# VynX AgentKit Plugin — Environment Configuration
# Copy this file to .env and fill in the values before running.
# NEVER commit .env to version control.

# -----------------------------------------------------------------------
# VynX Relayer endpoint
# The plugin POSTs signed EIP-712 intents to this URL at /v1/intents.
# Override this for local development or staging environments.
# Default (when unset): https://relayer.vynx.finance
# -----------------------------------------------------------------------
VYNX_RELAYER_URL=https://relayer.vynx.finance

# -----------------------------------------------------------------------
# Coinbase Developer Platform (CDP) credentials
# Required by the AgentKit consumer that instantiates CdpWalletProvider.
# Obtain these from https://portal.cdp.coinbase.com
# -----------------------------------------------------------------------
CDP_API_KEY_NAME=your-cdp-api-key-name
CDP_API_KEY_PRIVATE_KEY=your-cdp-api-key-private-key

# -----------------------------------------------------------------------
# LLM provider
# API key for the language model runtime that drives the AgentKit agent.
# -----------------------------------------------------------------------
OPENAI_API_KEY=your-openai-api-key
