# VynX AgentKit Plugin — Environment Configuration
# Copy this file to .env and populate every value before starting the agent runtime.
# NEVER commit a populated .env file to version control.

# -----------------------------------------------------------------------
# VynX Relayer endpoint
# -----------------------------------------------------------------------
# Fully qualified base URL of the VynX Relayer that ingests signed
# EIP-712 intents. The plugin POSTs to `${VYNX_RELAYER_URL}/v1/intents`.
# Override only when targeting a local development node or a private
# staging Relayer. Leave unset in production to use the canonical
# managed endpoint.
#
# Default (when unset): https://relayer.vynx.finance
# -----------------------------------------------------------------------
VYNX_RELAYER_URL=https://relayer.vynx.finance

# -----------------------------------------------------------------------
# Coinbase Developer Platform (CDP) — MPC Wallet credentials
# -----------------------------------------------------------------------
# These credentials authenticate the AgentKit `CdpWalletProvider` against
# the Coinbase Developer Platform MPC custody backend. Coinbase CDP is
# the institutional signing authority — the plugin never holds private
# keys directly; it only requests signatures through this provider.
#
# How to obtain:
#   1. Sign in to the Coinbase Developer Platform portal:
#        https://portal.cdp.coinbase.com
#   2. Navigate to: API Keys → Create API Key
#   3. Copy the generated `name` value into CDP_API_KEY_NAME
#   4. Copy the generated PEM-encoded private key into
#      CDP_API_KEY_PRIVATE_KEY (preserve newlines as `\n`)
#
# Treat CDP_API_KEY_PRIVATE_KEY with the same operational rigour as a
# production database credential. Never commit, log, or transmit it.
# -----------------------------------------------------------------------
CDP_API_KEY_NAME=your-cdp-api-key-name
CDP_API_KEY_PRIVATE_KEY=your-cdp-api-key-private-key

# -----------------------------------------------------------------------
# LLM provider credentials
# -----------------------------------------------------------------------
# API key for the language model runtime that drives the cognitive layer
# of the AgentKit agent. Required by the consuming application, not by
# this plugin directly. Obtain from your LLM provider's developer console
# (e.g. https://platform.openai.com/api-keys for OpenAI).
# -----------------------------------------------------------------------
OPENAI_API_KEY=your-openai-api-key
